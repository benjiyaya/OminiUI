# ── LLM (any OpenAI-compatible API) ──
# Works with: OpenAI, Ollama, Groq, Together, Fireworks, LM Studio, vLLM, etc.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3:8b

# Backward compat: if LLM_* not set, falls back to these
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_API_KEY=ollama
# OLLAMA_MODEL=

# ── Examples ──
# OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o
#
# Groq:
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=gsk_...
#   LLM_MODEL=llama-3.3-70b-versatile
#
# Together:
#   LLM_BASE_URL=https://api.together.xyz/v1
#   LLM_API_KEY=...
#   LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
#
# Ollama (local):
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_API_KEY=ollama
#   LLM_MODEL=qwen3:8b

# ── Prompt Enhancement (optional, separate from chat LLM) ──
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# Auto-save directory for generated images
RESULTS_DIR=results

# Auto-unload HiDream model after this many ms of inactivity (default 10 min)
MODEL_IDLE_TIMEOUT_MS=600000

# ── Server ──
PORT=3001

# ── MCP Servers Config ──
MCP_CONFIG_PATH=./mcp-servers.json

